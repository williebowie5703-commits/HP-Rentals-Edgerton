<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #111110;
    --off-white: #F5F3EE;
    --cream: #EAE6DC;
    --steel: #3A4A5C;
    --rust: #C04E1A;
    --rust-dark: #8E3410;
    --rust-light: #F0EBE6;
    --mid: #6B6B68;
    --border: rgba(0,0,0,0.12);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--off-white);
    color: var(--black);
    line-height: 1.6;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--black);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    height: 64px;
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: #fff;
    letter-spacing: 0.04em;
  }

  .nav-logo span { color: var(--rust); }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  nav ul a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  nav ul a:hover { color: #fff; }

  .nav-cta {
    background: var(--rust);
    color: #fff !important;
    padding: 0.45rem 1.1rem;
    border-radius: 4px;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: var(--rust-dark) !important; color: #fff !important; }

  /* HERO */
  .hero {
    background: var(--black);
    color: #fff;
    padding: clamp(4rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem);
    position: relative;
    overflow: hidden;
    min-height: 520px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent,
      transparent 60px,
      rgba(255,255,255,0.02) 60px,
      rgba(255,255,255,0.02) 61px
    ),
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 60px,
      rgba(255,255,255,0.02) 60px,
      rgba(255,255,255,0.02) 61px
    );
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 1.25rem;
    position: relative;
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.92;
    letter-spacing: 0.01em;
    position: relative;
    max-width: 900px;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--rust);
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.6);
    margin-top: 1.75rem;
    max-width: 480px;
    position: relative;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
    position: relative;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--rust);
    color: #fff;
    text-decoration: none;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary:hover { background: var(--rust-dark); transform: translateY(-1px); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: #fff;
    text-decoration: none;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    font-weight: 500;
    font-size: 0.95rem;
    border: 1.5px solid rgba(255,255,255,0.25);
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-secondary:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.05); }

  /* STRIP */
  .strip {
    background: var(--rust);
    color: #fff;
    padding: 1rem clamp(1.5rem, 5vw, 4rem);
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  .strip-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .strip-item svg { width: 18px; height: 18px; flex-shrink: 0; }

  /* SECTION */
  section {
    padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 5vw, 4rem);
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--black);
    margin-bottom: 1.5rem;
  }

  /* SERVICES */
  #services { background: var(--cream); }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5px;
    background: var(--border);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 3rem;
  }

  .service-card {
    background: var(--off-white);
    padding: 2rem;
    transition: background 0.2s;
  }

  .service-card:hover { background: #fff; }

  .service-icon {
    width: 48px;
    height: 48px;
    background: var(--rust-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .service-icon svg { width: 24px; height: 24px; color: var(--rust); }

  .service-card h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }

  .service-card p {
    font-size: 0.9rem;
    color: var(--mid);
    line-height: 1.65;
  }

  /* WHY */
  #why {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    background: var(--off-white);
    padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 5vw, 4rem);
  }

  .why-text p {
    color: var(--mid);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .why-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-box {
    background: var(--black);
    color: #fff;
    padding: 1.75rem;
    border-radius: 8px;
  }

  .stat-box .num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    color: var(--rust);
    line-height: 1;
  }

  .stat-box .label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin-top: 0.35rem;
  }

  /* CONTACT */
  #contact { background: var(--black); color: #fff; }

  #contact .section-title { color: #fff; }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .contact-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: background 0.2s, border-color 0.2s;
  }

  .contact-card:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.2);
  }

  .contact-card .c-label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 0.6rem;
    font-weight: 600;
  }

  .contact-card .c-value {
    font-size: 1.15rem;
    font-weight: 500;
  }

  .contact-card .c-icon {
    width: 36px;
    height: 36px;
    background: var(--rust);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .contact-card .c-icon svg { width: 18px; height: 18px; color: #fff; }

  .contact-cta {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .contact-cta p {
    color: rgba(255,255,255,0.5);
    font-size: 0.95rem;
    max-width: 380px;
  }

  /* FOOTER */
  footer {
    background: #0A0A09;
    color: rgba(255,255,255,0.4);
    text-align: center;
    padding: 2rem;
    font-size: 0.85rem;
  }

  footer strong { color: rgba(255,255,255,0.7); }

  /* RESPONSIVE */
  @media (max-width: 700px) {
    #why { grid-template-columns: 1fr; }
    nav ul { display: none; }
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow { animation: fadeUp 0.5s ease both; }
  .hero h1 { animation: fadeUp 0.5s 0.1s ease both; }
  .hero-sub { animation: fadeUp 0.5s 0.2s ease both; }
  .hero-actions { animation: fadeUp 0.5s 0.3s ease both; }
</style>
</head>
